# Discord Bot Configuration
# Get your token from: https://discord.com/developers/applications

# Bot Token (REQUIRED)
DISCORD_TOKEN=your_bot_token_here

# Application ID (REQUIRED for slash commands)
# Found in Discord Developer Portal -> General Information
CLIENT_ID=your_application_id_here

# Guild ID (OPTIONAL - for dev server only)
# Leave empty to register commands globally (takes up to 1 hour)
# Fill in to register instantly for a specific server
GUILD_ID=your_test_server_id_here

# ========================================
# OpenCode 集成配置
# ========================================

# 工作区目录 - OpenCode 可以访问的根目录
# 此目录下的子文件夹会在 /opencode 命令中显示
WORKSPACE_DIR=/home/better/dev/repo

# OpenCode ACP 服务端点
# OpenCode 服务接收任务的地址
OPENCODE_ACP_URL=http://localhost:3000

# Bot ACP 回调配置
# 用于接收 OpenCode 处理结果的 HTTP 端点
# 这个地址需要能被 OpenCode 访问到
BOT_ACP_PORT=8080
BOT_ACP_ENDPOINT=http://localhost:8080/acp/callback
